{
  "Llm": {
    "Provider": "none",
    "OpenAiModel": "gpt-4.1-mini",
    "TogetherModel": "meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo",
    "OpenAiApiKey": "",
    "TogetherApiKey": "",
    "OpenAiBaseUrl": "https://api.openai.com/v1",
    "TogetherBaseUrl": "https://api.together.xyz/v1"
  },
  "Mcp": {
    "BaseUrl": "http://localhost:5000",
    "ToolRoute": "/mcp/tool",
    "TimeoutSeconds": 60,
    "UseMockResponses": true
  },
  "Analysis": {
    "YieldStrengthByMaterialMpa": {
      "Mild Steel": 210,
      "Medium Carbon Steel": 420,
      "Alloy Steel": 850,
      "Aluminium 6061-T6": 276,
      "Nylon PA66": 85
    },
    "LewisFormFactorByTeeth": {
      "12": 0.245,
      "16": 0.289,
      "20": 0.322,
      "24": 0.343,
      "30": 0.365,
      "40": 0.392,
      "60": 0.421,
      "80": 0.435,
      "120": 0.452
    },
    "SafetyFactorWarningThreshold": 1.5,
    "SafetyFactorFailThreshold": 1.0,
    "MinWallThicknessInjectionMoldingMm": 1.5,
    "MinWallThicknessMetalSinteringMm": 0.8,
    "MinDraftAngleDeg": 1.0,
    "MinThreadPitchMm": 0.5,
    "MaxThreadPitchMm": 6.0
  },
  "Output": {
    "RootDirectory": "outputs",
    "SessionIsolationEnabled": true
  },
  "Throttle": {
    "Enabled": true,
    "PermitLimitPerMinute": 120
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
